{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$API_PROXY_URL/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "$API_PROXY_URL/media/:path*"
    },
    {
      "source": "/preview/:path*",
      "destination": "$API_PROXY_URL/preview/:path*"
    },
    {
      "source": "/stream/:path*",
      "destination": "$API_PROXY_URL/stream/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
