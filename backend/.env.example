# App
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
MONGODB_URI=mongodb://mongo:27017/media_storage

# Queues
QUEUE_DRIVER=memory
# QUEUE_DRIVER=bullmq
# REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Optional Google OAuth
# Google Console redirect URI:
# http://localhost:4000/api/auth/google/callback
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Optional Telegram fallback
# Telegram credentials are normally connected per user workspace in the dashboard.
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHANNEL_ID=-1001234567890

# Storage
STORAGE_PROVIDER=telegram
MAX_UPLOAD_MB=2048
DEFAULT_WORKSPACE_STORAGE_LIMIT_GB=0

# Local temp/cache paths
LOCAL_CACHE_DIR=tmp/cache
UPLOAD_TMP_DIR=tmp/uploads
CACHE_TTL_SECONDS=3600
CACHE_MAX_MB=512
TEMP_FILE_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=900

# Security
SIGNED_URL_SECRET=change-me-to-another-long-random-secret
ENCRYPTION_SECRET=change-me-to-a-very-long-32-plus-character-secret
SIGNED_URL_TTL_SECONDS=900

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
