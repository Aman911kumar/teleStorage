NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MONGODB_URI=mongodb://mongo:27017/media_storage
QUEUE_DRIVER=memory
# Use bullmq in production or when Redis is available:
# QUEUE_DRIVER=bullmq
# REDIS_URL=redis://redis:6379

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Telegram credentials are connected per user workspace in the dashboard.
# Optional fallback only if you instantiate TelegramStorageProvider without workspace credentials:
# TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_CHANNEL_ID=-1001234567890

STORAGE_PROVIDER=telegram
MAX_UPLOAD_MB=2048
DEFAULT_WORKSPACE_STORAGE_LIMIT_GB=0
LOCAL_CACHE_DIR=tmp/cache
UPLOAD_TMP_DIR=tmp/uploads
CACHE_TTL_SECONDS=3600
CACHE_MAX_MB=512
TEMP_FILE_TTL_SECONDS=3600
CLEANUP_INTERVAL_SECONDS=900
SIGNED_URL_SECRET=change-me-to-another-long-random-secret
ENCRYPTION_SECRET=change-me-to-a-very-long-32-plus-character-secret
SIGNED_URL_TTL_SECONDS=900

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
